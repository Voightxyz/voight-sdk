{
  "name": "@voightxyz/sdk",
  "version": "0.3.9",
  "description": "Real-time observability for AI agents on Solana. A 3-line SDK, a live timeline, and an on-chain audit trail.",
  "keywords": [
    "solana",
    "ai-agents",
    "observability",
    "voight",
    "agent-registry",
    "x402",
    "eliza",
    "solana-agent-kit"
  ],
  "homepage": "https://voight.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voightxyz/voight-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/voightxyz/voight-sdk/issues"
  },
  "license": "MIT",
  "author": "Voight (https://voight.xyz)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
